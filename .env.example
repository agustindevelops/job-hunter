# Optional local AI defaults (checked before the API key modal).
# Copy to `.env.local` and fill in. Restart `yarn dev` after changes.
#
# These NEXT_PUBLIC_* values are exposed to the browser bundle — use only
# for local development. Do not commit real keys.

NEXT_PUBLIC_AI_API_KEY=
NEXT_PUBLIC_AI_MODEL=gpt-5.6-terra

# Optional: override the provider base URL (e.g. local Ollama proxy)
# NEXT_PUBLIC_AI_BASE_URL=http://localhost:11434/v1
